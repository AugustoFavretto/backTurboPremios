# Database (Supabase PostgreSQL)
DATABASE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-supabase-db-password

# JWT
JWT_SECRET=your-very-long-secret-key-minimum-256-bits-here-change-in-production
JWT_EXPIRATION=86400000

# PIX Gateway
PIX_GATEWAY=mock
PIX_KEY=turbo@premios.com.br
PIX_MERCHANT_NAME=Turbo Premios
PIX_MERCHANT_CITY=SAO PAULO

# Frontend
FRONTEND_BASE_URL=https://turbopremios.com.br

# Mail (optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Affiliate
AFFILIATE_COMMISSION_RATE=10.0

# App
SPRING_PROFILES_ACTIVE=prod
PORT=8080
LOG_LEVEL=INFO
